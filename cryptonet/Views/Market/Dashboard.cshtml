@model List<cryptonet.Models.MarketCoinViewModel>

@{
    var querySearch = Context.Request.Query["search"];
    var querySort = Context.Request.Query["sortBy"];
    ViewData["Title"] = "Market Dashboard | CryptoNet";
}

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="container">

        <div class="mb-4">
            <h2 class="fw-bold text-dark mb-1">📊 Market Dashboard</h2>
            <p class="text-muted small">Обзор криптовалютного рынка в реальном времени</p>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-3 mb-4 bg-white">
            <form class="row g-3" method="get">
                <div class="col-md-6">
                    <div class="input-group bg-light rounded-3 overflow-hidden border">
                        <span class="input-group-text border-0 bg-transparent opacity-50"><i class="bi bi-search">🔍</i></span>
                        <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none ps-0"
                               placeholder="Поиск монеты (напр. Bitcoin)..." value="@querySearch">
                    </div>
                </div>

                <div class="col-md-4">
                    <select name="sortBy" class="form-select bg-light border-0 shadow-none rounded-3 py-2">
                        <option value="">Сортировка по умолчанию</option>
                        <option value="price" selected="@(querySort == "price")">💰 Цена</option>
                        <option value="change" selected="@(querySort == "change")">📈 Изм. 24ч %</option>
                        <option value="marketcap" selected="@(querySort == "marketcap")">🏛 Капитализация</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100 rounded-3 py-2 fw-bold shadow-sm">Применить</button>
                </div>
            </form>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-white text-uppercase smaller fw-bold text-muted border-bottom">
                        <tr>
                            <th class="ps-4 py-3">#</th>
                            <th class="py-3">Монета</th>
                            <th class="py-3">Цена</th>
                            <th class="py-3">24ч %</th>
                            <th class="py-3">Объем</th>
                            <th class="py-3">Капитализация</th>
                            <th class="py-3 text-center">Избранное</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white">
                        @foreach (var coin in Model)
                        {
                            var change = coin.PercentChange24h ?? 0;
                            var changeClass = change >= 0 ? "text-success" : "text-danger";

                            <tr>
                                <td class="ps-4 text-muted small">@coin.MarketRank</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="coin-symbol-box me-3">@coin.Symbol.ToUpper().Substring(0, 1)</div>
                                        <div>
                                            <a asp-controller="Coin" asp-action="Details" asp-route-id="@coin.CoinId"
                                               class="text-decoration-none text-dark fw-bold d-block">
                                                @coin.Name
                                            </a>
                                            <span class="text-muted smaller">@coin.Symbol.ToUpper()</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-bold text-dark">
                                    @coin.Price.ToString(coin.Price < 1 ? "N6" : "N2") $
                                </td>
                                <td class="@changeClass fw-bold">
                                    @(change >= 0 ? "▲" : "▼") @Math.Abs(change).ToString("N2")%
                                </td>
                                <td class="text-muted small">@coin.Volume24h?.ToString("N0") $</td>
                                <td class="text-muted small">@coin.MarketCap?.ToString("N0") $</td>
                                <td class="text-center">
                                    @if (coin.IsFavorite)
                                    {
                                        <form method="post" asp-controller="Favorites" asp-action="Remove" class="d-inline">
                                            <input type="hidden" name="coinId" value="@coin.CoinId" />
                                            <button class="btn btn-favorite active shadow-none">★</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-controller="Favorites" asp-action="Add" class="d-inline">
                                            <input type="hidden" name="coinId" value="@coin.CoinId" />
                                            <button class="btn btn-sm btn-outline-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#addToGroupModal"
                                                    onclick="setCoinForGroup(@coin.CoinId, '@coin.Name')">
                                                ☆
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="modal fade" id="addToGroupModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow rounded-4">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="fw-bold">Добавить в список</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-controller="Favorites" asp-action="Add" method="post">
                        <div class="modal-body p-4">
                            <input type="hidden" name="coinId" id="modalCoinId" />
                            <p class="text-muted small">Выберите группу для монеты <span id="modalCoinName" class="fw-bold text-dark"></span></p>

                            <div class="mb-3">
                                <label class="form-label small fw-bold">Список наблюдения</label>
                                <select name="groupId" class="form-select bg-light border-0 py-2">
                                    <option value="">-- Общий список (без группы) --</option>
                                    @if (ViewBag.UserGroups != null)
                                    {
                                        foreach (var g in ViewBag.UserGroups)
                                        {
                                            <option value="@g.Id">@g.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0 p-4">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Добавить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;"></div>

<style>
    /* Бейдж символа */
    .coin-symbol-box {
        width: 32px;
        height: 32px;
        background: #f1f3f5;
        color: #495057;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.8rem;
    }

    /* Кнопка избранного */
    .btn-favorite {
        color: #dee2e6;
        font-size: 1.2rem;
        background: none;
        border: none;
        transition: all 0.2s;
    }

        .btn-favorite:hover {
            color: #ffc107;
            transform: scale(1.2);
        }

        .btn-favorite.active {
            color: #ffc107;
        }

    /* Таблица */
    .smaller {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: background 0.2s ease;
        cursor: pointer;
    }

        .table tbody tr:hover {
            background-color: #fbfcfe;
        }

    /* Дизайн Toast */
    .custom-toast {
        background: #ffffff;
        border-left: 5px solid #0d6efd;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        min-width: 300px;
        animation: slideIn 0.3s ease-out;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
        }

        to {
            transform: translateX(0);
        }
    }
</style>

<script>
    // Загрузка уведомлений
    window.addEventListener("load", async () => {
        const res = await fetch("/Market/GetTriggeredAlerts");
        const alerts = await res.json();
        alerts.forEach(a => showToast(a));
    });

    function showToast(a) {
        const container = document.getElementById("toastContainer");
        const toast = document.createElement("div");
        toast.className = "custom-toast d-flex align-items-center justify-content-between";

        toast.innerHTML = `
            <div class="me-3">
                <div class="fw-bold text-dark">🚨 Цель достигнута!</div>
                <div class="small text-muted">${a.name} (${a.symbol}) — ${a.current}$</div>
            </div>
            <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="markRead(${a.id}, this)">ОК</button>
        `;

        container.appendChild(toast);
        setTimeout(() => { if(toast) toast.remove(); }, 10000);
    }

    async function markRead(id, btn) {
        await fetch(`/Market/MarkAsRead?id=${id}`, { method: "POST" });
        btn.closest(".custom-toast").remove();
    }

    function setCoinForGroup(id, name) {
        document.getElementById('modalCoinId').value = id;
        document.getElementById('modalCoinName').innerText = name;
    }
</script>