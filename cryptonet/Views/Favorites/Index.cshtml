@model List<cryptonet.Models.MarketCoinViewModel>

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="container">
        <div class="mb-4">
            <h2 class="fw-bold text-dark mb-1">⭐ Избранные монеты</h2>
            <p class="text-muted small">Ваш персональный список активов для быстрого доступа</p>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 shadow-sm bg-white rounded-4">
                <div class="mb-3 opacity-25">
                    <i class="bi bi-star" style="font-size: 5rem;"></i>
                </div>
                <h4 class="text-muted">Список избранного пока пуст</h4>
                <p class="text-muted small">Добавляйте монеты со страницы рынка, нажимая на звёздочку.</p>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-white text-uppercase smaller fw-bold text-muted border-bottom">
                            <tr>
                                <th class="ps-4 py-3">Монета</th>
                                <th class="py-3 text-end">Цена</th>
                                <th class="py-3 text-end">24ч Изменение</th>
                                <th class="py-3 text-end pe-4">Действия</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var coin in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="coin-icon-mini me-3">@coin.Symbol.ToUpper().Substring(0, 1)</div>
                                            <div>
                                                <a asp-controller="Coin" asp-action="Details" asp-route-id="@coin.CoinId" class="text-decoration-none text-dark fw-bold d-block">
                                                    @coin.Name
                                                </a>
                                                <span class="text-muted smaller">@coin.Symbol.ToUpper()</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">@coin.Price.ToString("N2") $</td>
                                    <td class="text-end">
                                        <div class="fw-bold @(coin.PercentChange24h >= 0 ? "text-success" : "text-danger")">
                                            @(coin.PercentChange24h >= 0 ? "▲" : "▼") @Math.Abs(coin.PercentChange24h ?? 0).ToString("N2")%
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="Remove" method="post" onsubmit="return confirm('Удалить из избранного?');">
                                            <input type="hidden" name="coinId" value="@coin.CoinId" />
                                            <button type="submit" class="btn btn-link text-danger text-decoration-none shadow-none p-0">
                                                <i class="bi bi-trash"></i> Удалить
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>


<style>
    /* Группировка */
    .group-dot {
        width: 10px;
        height: 10px;
        background: #0d6efd;
        border-radius: 50%;
        box-shadow: 0 0 10px rgba(13,110,253,0.4);
    }

    /* Иконка монеты */
    .coin-symbol-circle {
        width: 32px;
        height: 32px;
        background: #f1f3f5;
        color: #495057;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.8rem;
        border: 1px solid #dee2e6;
    }

    /* Таблица */
    .table tbody tr {
        transition: background 0.2s ease;
        cursor: pointer;
    }

        .table tbody tr:hover {
            background-color: #f8f9fa;
        }

    .smaller {
        font-size: 0.75rem;
    }

    /* Кнопка удаления */
    .btn-action-remove {
        color: #adb5bd;
        border: none;
        background: none;
        transition: all 0.2s;
        font-size: 1.1rem;
    }

        .btn-action-remove:hover {
            color: #dc3545;
            transform: scale(1.1);
        }

</style>