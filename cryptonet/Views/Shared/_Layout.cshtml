@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CryptoNet</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Market" asp-action="Dashboard">CryptoNet</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Market" ? "active" : "")" asp-controller="Market" asp-action="Dashboard">📊 Market</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Favorites" ? "active" : "")" asp-controller="Favorites" asp-action="Index">⭐ Favorites</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Portfolio" ? "active" : "")" asp-controller="Portfolio" asp-action="Index">💼 Portfolio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Alerts" ? "active" : "")" asp-controller="Alerts" asp-action="Index">🔔 Alerts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "News" ? "active" : "")" asp-controller="News" asp-action="Index">📰 News</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "AiAssistant" ? "active" : "")" asp-controller="AiAssistant" asp-action="Index">🤖 AI Assistant</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        @if (string.IsNullOrEmpty(Context.Session.GetString("Username")))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @Context.Session.GetString("Username")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Logout</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2026 - CryptoNet - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/alerthub")
            .build();

        connection.on("alertTriggered", function (data) {
            // Чтобы не пугать пользователя обычным alert, лучше выводить консоль или тост
            console.log("🚨 SignalR Alert:", data);
            // alert("🚨 Уведомление: " + data);
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
</body>
</html>