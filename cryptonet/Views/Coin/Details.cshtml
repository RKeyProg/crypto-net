@model cryptonet.Models.MarketCoinViewModel

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mb-4 mt-3 mx-3">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    ViewData["Title"] = $"{Model.Name} ({Model.Symbol})";
}

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="container">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="d-flex align-items-center">
                <div class="coin-logo-large shadow-sm me-3">
                    @Model.Symbol.ToUpper().Substring(0, 1)
                </div>
                <div>
                    <h1 class="fw-bold mb-0">@Model.Name <span class="text-muted fw-normal fs-4">@Model.Symbol.ToUpper()</span></h1>
                    <span class="badge bg-dark rounded-pill">Rank #@(Model.MarketRank?.ToString() ?? "—")</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addToPortfolioModal">
                    <i class="bi bi-plus-lg me-2"></i> В портфель
                </button>
                <button class="btn btn-outline-secondary rounded-pill px-3 shadow-sm bg-white">
                    <i class="bi bi-star me-1"></i>
                </button>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4 col-xl-3">
                <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-0 h-100">
                    <small class="text-muted text-uppercase fw-bold smaller">Текущая цена</small>
                    <h3 class="fw-bold mb-0 mt-1">@Model.Price.ToString("N2") $</h3>
                    <div class="mt-2 @(Model.PercentChange24h >= 0 ? "text-success" : "text-danger") fw-bold small">
                        <i class="bi @(Model.PercentChange24h >= 0 ? "bi-caret-up-fill" : "bi-caret-down-fill")"></i>
                        @Model.PercentChange24h?.ToString("N2")% <span class="text-muted fw-normal">(24ч)</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-3">
                <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-0 h-100">
                    <small class="text-muted text-uppercase fw-bold smaller">Рыночная капа</small>
                    <h3 class="fw-bold mb-0 mt-1">@Model.MarketCap?.ToString("N0") $</h3>
                    <p class="text-muted small mt-2 mb-0">Общая рыночная стоимость</p>
                </div>
            </div>
            <div class="col-md-4 col-xl-3">
                <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-0 h-100">
                    <small class="text-muted text-uppercase fw-bold smaller">Объем торгов</small>
                    <h3 class="fw-bold mb-0 mt-1">@((Model.Volume24h ?? 0).ToString("N2")) $</h3>
                    <p class="text-muted small mt-2 mb-0">За последние 24 часа</p>
                </div>
            </div>
            <div class="col-md-12 col-xl-3">
                <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-0 h-100">
                    <small class="text-muted text-uppercase fw-bold smaller">Предложение</small>
                    <div class="mt-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Циркулирует</span>
                            <span class="fw-bold">@Model.CirculatingSupply?.ToString("N0")</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar bg-primary" style="width: 65%"></div>
                        </div>
                        <div class="d-flex justify-content-between smaller text-muted mt-1">
                            <span>Max: @(Model.MaxSupply.HasValue? Model.MaxSupply.Value.ToString("N0") : "∞")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-bold mb-0">Динамика рынка</h4>
                        <div class="btn-group btn-group-sm bg-light p-1 rounded-pill">
                            <button class="btn btn-primary rounded-pill px-3 border-0" data-period="7">7Д</button>
                            <button class="btn btn-light rounded-pill px-3 border-0" data-period="30">1М</button>
                            <button class="btn btn-light rounded-pill px-3 border-0" data-period="365">1Г</button>
                        </div>
                    </div>
                    <canvas id="priceChart" style="max-height: 400px;"></canvas>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="ai-analysis-card p-4 rounded-4 shadow-lg text-white h-100" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
                    <div class="d-flex align-items-center mb-3">
                        <div class="ai-icon-pulse me-3">🤖</div>
                        <h4 class="fw-bold mb-0">AI Intelligence</h4>
                    </div>
                    <hr class="opacity-25">

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="opacity-75">Тренд</span>
                            <span class="badge @(ViewBag.Trend == "bullish" ? "bg-success" : "bg-danger") px-3">@ViewBag.Trend</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="opacity-75">Риск-фактор</span>
                            <span class="fw-bold @(ViewBag.Risk == "high" ? "text-warning" : "text-info") text-uppercase">@ViewBag.Risk</span>
                        </div>
                    </div>

                    <div class="forecast-box p-3 rounded-3 bg-white bg-opacity-10 mb-4 border border-white border-opacity-10">
                        <small class="d-block opacity-75 mb-2">Прогноз на 5 дней</small>
                        <div class="fw-bold fs-5">
                            @if (ViewBag.Forecast != null)
                            {
                                @string.Join(" ➔ ", ((List<decimal>)ViewBag.Forecast).Select(f => f.ToString("N1") + "$"))
                            }
                        </div>
                    </div>

                    <div class="explanation">
                        <small class="d-block opacity-50 text-uppercase fw-bold mb-2 smaller">Аналитическая заметка</small>
                        <p class="fst-italic small opacity-75">"@ViewBag.Explanation"</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="addToPortfolioModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Добавить в портфель</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-controller="Portfolio" asp-action="Add">
                <input type="hidden" name="coinId" value="@Model.CoinId">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Количество</label>
                        <input id="quantityInput" name="quantity" type="number" step="0.0001" class="form-control form-control-lg bg-light border-0 shadow-none rounded-3" required placeholder="0.00">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Цена покупки ($)</label>
                        <input id="priceInput" name="buyPrice" type="number" step="0.01" class="form-control form-control-lg bg-light border-0 shadow-none rounded-3" value="@Model.Price" required>
                    </div>
                    <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-primary small fw-bold">ИТОГО К ОПЛАТЕ:</span>
                            <span id="totalInput" class="h4 mb-0 fw-bold text-primary">0.00 $</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 p-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4 shadow-sm">Добавить актив</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .coin-logo-large {
        width: 60px;
        height: 60px;
        background: #000;
        color: #fff;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: bold;
    }

    .stats-card {
        transition: transform 0.2s;
    }

        .stats-card:hover {
            transform: translateY(-5px);
        }

    .smaller {
        font-size: 0.7rem;
        letter-spacing: 1px;
    }

    .ai-analysis-card {
        position: relative;
        overflow: hidden;
    }

    .ai-icon-pulse {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: pulse-border 2s infinite;
    }

    @@keyframes pulse-border {
        0% {
            box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(59, 130, 246, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(59, 130, 246, 0);
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Твоя логика графика и расчетов остается, я только обновил стили цветов
    const ctx = document.getElementById('priceChart').getContext('2d');
    let labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PriceLabels));
    let prices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PriceData));

    let priceChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Цена',
                data: prices,
                borderColor: '#3b82f6',
                borderWidth: 3,
                backgroundColor: 'rgba(59, 130, 246, 0.05)',
                fill: true,
                tension: 0.4,
                pointRadius: 0
            },
            {
                label: 'AI Прогноз',
                data: [],
                borderColor: '#10b981',
                borderDash: [5, 5],
                fill: false,
                pointRadius: 0
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { grid: { color: '#f1f3f5' } }
            }
        }
    });

    // Расчет в модалке
    const qtyInp = document.getElementById('quantityInput');
    const priceInp = document.getElementById('priceInput');
    const totalInp = document.getElementById('totalInput');

    const calculate = () => {
        const res = (parseFloat(qtyInp.value) || 0) * (parseFloat(priceInp.value) || 0);
        totalInp.innerText = res.toLocaleString('ru-RU', {minimumFractionDigits: 2}) + ' $';
    };
    qtyInp.oninput = calculate;
    priceInp.oninput = calculate;
</script>